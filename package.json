{
  "name": "astrostack",
  "version": "0.0.0",
  "private": true,
  "description": "AstroStack — a line of Astro-native components you install into your own src/ and fully own.",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "cli": "pnpm --filter @astrostack/cli exec astrostack",
    "cli:build": "pnpm --filter @astrostack/cli build",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build"
  },
  "packageManager": "pnpm@10.28.1"
}
