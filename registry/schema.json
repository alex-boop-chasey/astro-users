{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/alex-boop-chasey/astro-users/main/registry/schema.json",
  "title": "Astro Users component manifest",
  "type": "object",
  "required": ["name", "title", "description", "tier", "version", "files"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string", "description": "CLI slug, e.g. \"auth\"", "pattern": "^[a-z][a-z0-9-]*$" },
    "title": { "type": "string" },
    "npmName": { "type": "string", "description": "Public/marketing package name, e.g. \"astro-auth\"" },
    "aliases": { "type": "array", "items": { "type": "string" } },
    "description": { "type": "string" },
    "tier": { "type": "string", "enum": ["free", "pro"] },
    "version": { "type": "string" },
    "homepage": { "type": "string" },
    "license": { "type": "string" },
    "requires": {
      "type": "array",
      "description": "Slugs of other Astro Users components that must be installed first",
      "items": { "type": "string" }
    },
    "npmDependencies": {
      "type": "object",
      "description": "npm packages the component needs, name -> semver range",
      "additionalProperties": { "type": "string" }
    },
    "astro": {
      "type": "object",
      "properties": {
        "output": { "type": "string", "enum": ["static", "server", "hybrid"] },
        "adapterRequired": { "type": "boolean" }
      }
    },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file" }
    },
    "env": {
      "type": "array",
      "items": { "$ref": "#/$defs/envVar" }
    },
    "variants": {
      "type": "array",
      "description": "Install-time choices that swap in provider-specific files/env/deps (e.g. CAPTCHA provider)",
      "items": {
        "type": "object",
        "required": ["id", "options"],
        "properties": {
          "id": { "type": "string", "description": "Variant slug, e.g. \"captcha\"", "pattern": "^[a-z][a-z0-9-]*$" },
          "prompt": { "type": "string", "description": "Question shown when selecting interactively" },
          "default": { "type": "string", "description": "Option id used non-interactively (--yes) or as the initial selection" },
          "options": {
            "type": "object",
            "description": "Map of option id -> what installing that option contributes",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "label": { "type": "string" },
                "hint": { "type": "string" },
                "files": {
                  "type": "array",
                  "items": { "$ref": "#/$defs/file" },
                  "description": "Files read from variants/<id>/<option>/<path>"
                },
                "env": { "type": "array", "items": { "$ref": "#/$defs/envVar" } },
                "npmDependencies": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "postInstall": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        }
      }
    },
    "postInstall": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "target"],
      "properties": {
        "path": { "type": "string", "description": "Path within the component's files/ dir (or a variant option dir)" },
        "target": { "type": "string", "description": "Destination path relative to the project root" },
        "type": { "type": "string" }
      }
    },
    "envVar": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "prompt": { "type": "string" },
        "required": { "type": "boolean" },
        "public": { "type": "boolean" },
        "secret": { "type": "boolean" },
        "example": { "type": "string" }
      }
    }
  }
}
